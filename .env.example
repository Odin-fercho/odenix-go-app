EXPO_NO_CLIENT_ENV_VARS=1
# App cliente (web): https://go.odenix.shop — API / datos vía portal: https://hub.odenix.shop
# Opcional: prioridad sobre el hub por defecto en release (otros tenants / staging).
# EXPO_PUBLIC_PORTAL_URL=https://hub.odenix.shop
# Desarrollo local del portal (solo __DEV__ si no defines EXPO_PUBLIC_PORTAL_URL):
# EXPO_PUBLIC_PORTAL_URL_DEV=http://127.0.0.1:3000
# Slug del cliente en Baserow (también en app.json → extra.tenantSlug para builds sin .env en cliente)
EXPO_PUBLIC_CURRENT_TENANT_SLUG=odenix_studio
